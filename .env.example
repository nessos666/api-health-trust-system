# API Health Trust System – Configuration
# Copy this file to .env and fill in your values.

# Target API endpoint to monitor
API_URL=https://api.example.com/health

# Health check interval in seconds (default: 300)
CHECK_INTERVAL=300

# Output file for health results (read by external tools)
HEALTH_OUTPUT=/tmp/api_health.json

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
